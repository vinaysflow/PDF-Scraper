# --- API Authentication (optional, leave empty to disable) ---
API_KEY=

# --- OCR Engine ---
# Options: tesseract (default), paddleocr
OCR_ENGINE=tesseract
OCR_WORKERS=4

# --- Sarvam Vision (regional Indian language OCR, optional) ---
SARVAM_API_KEY=
SARVAM_CHUNK_PAGES=5
SARVAM_MAX_WORKERS=2

# --- OpenAI (optional, for diagram VLM + question enrichment) ---
OPENAI_API_KEY=
ENRICHMENT_MODEL=gpt-4o-mini
VLM_WORKERS=5

# --- Supabase (optional, for question bank ingestion) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Limits ---
SYNC_MAX_PAGES=50
ASYNC_MAX_PAGES=500
SAFE_DPI=300
SAFE_BATCH_PAGES=3
MAX_FILE_SIZE_BYTES=20971520
ASYNC_WORKERS=1

# --- Feature Flags (set to 1 to enable) ---
EXTRACT_IMAGES=
EXTRACT_LAYOUT=
EXTRACT_TABLES=
EXTRACT_MATH=
INCLUDE_BASE64_IMAGES=

# --- Storage ---
IMAGE_STORE_DIR=./image_store
JOB_STORE_DIR=/tmp/job_store
